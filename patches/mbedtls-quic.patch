+#if defined(MBEDTLS_SSL_LWS_QUIC_SUPPORT)
+int mbedtls_ssl_write_custom_exts(mbedtls_ssl_context *ssl,
+                                  unsigned int context,
+                                  unsigned char *buf,
+                                  unsigned char *end,
+                                  size_t *out_len)
+{
+    unsigned char *p = buf;
+    mbedtls_ssl_custom_ext_t *ext;
+    size_t ext_len;
+
+    *out_len = 0;
+
+    for (ext = ssl->custom_exts; ext != NULL; ext = ext->next) {
+        if ((ext->context_mask & context) == 0 || ext->write_cb == NULL) {
+            continue;
+        }
+
+        MBEDTLS_SSL_CHK_BUF_PTR(p, end, 4);
+
+        if (ext->write_cb(ssl, ext->ext_type, context, p + 4, (size_t) (end - p - 4), &ext_len, ext->custom_ctx) != 0) {
+            return MBEDTLS_ERR_SSL_INTERNAL_ERROR;
+        }
+
+        if (ext_len > 0) {
+            MBEDTLS_PUT_UINT16_BE(ext->ext_type, p, 0);
+            MBEDTLS_PUT_UINT16_BE(ext_len, p, 2);
+            p += 4 + ext_len;
+        }
+    }
+
+    *out_len = (size_t) (p - buf);
+    return 0;
+}
+
+int mbedtls_ssl_parse_custom_ext(mbedtls_ssl_context *ssl,
+                                 unsigned int context,
+                                 unsigned int ext_type,
+                                 const unsigned char *buf,
+                                 size_t len)
+{
+    mbedtls_ssl_custom_ext_t *ext;
+
+    for (ext = ssl->custom_exts; ext != NULL; ext = ext->next) {
+        if (ext->ext_type == ext_type && (ext->context_mask & context) != 0) {
+            if (ext->parse_cb != NULL) {
+                return ext->parse_cb(ssl, ext_type, context, buf, len, ext->custom_ctx);
+            }
+            return 0; /* Known extension, but no parse callback (maybe write-only) */
+        }
+    }
+
+    /* Not handled by custom extensions */
+    return MBEDTLS_ERR_SSL_FEATURE_UNAVAILABLE;
+}
+#endif
