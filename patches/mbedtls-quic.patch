+#if defined(MBEDTLS_SSL_PROTO_TLS1_3)
+    if (ssl->handshake != NULL) {
+#if defined(MBEDTLS_SSL_EARLY_DATA)
+        if (transform == ssl->handshake->transform_earlydata) {
+            return MBEDTLS_SSL_QUIC_ENC_LEVEL_EARLY_DATA;
+        }
+#endif
+        if (transform == ssl->handshake->transform_handshake) {
+            return MBEDTLS_SSL_QUIC_ENC_LEVEL_HANDSHAKE;
+        }
+    }
+    if (transform == ssl->transform_application) {
+        return MBEDTLS_SSL_QUIC_ENC_LEVEL_APPLICATION;
+    }
+#endif /* MBEDTLS_SSL_PROTO_TLS1_3 */
+
+    return MBEDTLS_SSL_QUIC_ENC_LEVEL_INITIAL; /* Fallback */
